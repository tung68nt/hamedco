font-family: Verdana,Geneva,sans-serif;font-size: 12px;line-height: 16px;}/* Custom CSS Mobile */@media (max-width: 549px){.header-inner {padding:5px;width: 100%;background: url(https://bvdkkvquangnam.org/wp-content/uploads/2020/12/Header_new-copy.png);background-size: cover;}#logo img{display:none}}.label-new.menu-item > a:after{content:"New";}.label-hot.menu-item > a:after{content:"Hot";}.label-sale.menu-item > a:after{content:"Sale";}.label-popular.menu-item > a:after{content:"Popular";}</style>		<style type="text/css" id="wp-custom-css">
			h1, h2, h3, h4, h5, h6, .heading-font{
    color: #005c7d;
	  font-weight: 000;
    font-size: 14px;
}
.bg {
      background: #f5f6f7;
}		</style>
		<style id="sccss">/* Điền CSS tùy chỉnh ở đây */
.chuyenkhoa #toc_container {
	display:none!important;
} 

.html .social-icons .button {
	color: #fff;
}
.html .social-icons .button i {
	top: 0;
}
.nav-small.nav>li.html {
	display: flex;
}

#section_505197941 .section-bg-overlay {
	background: #2aacf1;
}

.header-inner {
	width: 100%;
}
@media (max-width: 549px) {
	.header-main {
    height: 94px;
		margin-bottom:10px;
		margin-top:10px;
	}
}
.group-button a i:before {
    display: inline-block;
    margin-right: 14px;
    vertical-align: middle;
}
.group-button .button {
	padding: 8px 12px;
}
.icon-sf-calc:before {
    content: url('/wp-content/uploads/2022/06/icon-calc-hover.png');
}

.icon-sf-doctor:before {
    content: url('/wp-content/uploads/2022/06/icon-tool-hover.png');
}
.tbs__banner {
	position: relative;
}
.tbs__title {
	padding: 30px 0;
    text-transform: uppercase;
    text-align: center;
    font-size: 24px;
    color: #2aacf1;
}
.tbs__banner__buttons {
	position: absolute;
    top: 15%;
    left: 24px;
}
.tbs__grid {
	display:grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 30px;
	padding: 0 24px;
}
@media (min-width: 768px) {
	.tbs__grid {
		grid-template-columns: repeat(4, 1fr);
	}
}

.tbs__item-title {
		padding-top: 10px;
    text-align: center;
    text-transform: uppercase;
    font-size: 16px;
}

.tbs__item-excerpt {
	text-align: center;
	font-size: 13px;
}
@media (min-width: 768px) {
	.tbs__item-excerpt {
	font-size: 15px;
}
}


.tbs__paginate {
	display: flex;
	padding: 24px;
	justify-content: center;
}
.tbs__paginate span, .tbs__paginate a {

    box-sizing: border-box;
    font-size: 18px !important;
    font-weight: bold;
    vertical-align: middle;
    background-color: #fff;
    border: 1px solid #d7d7d7;
    outline: 0;
    text-decoration: none;
    -webkit-transition: all 0.3s ease;
    -moz-transition: all 0.3s ease;
    -o-transition: all 0.3s ease;
    transition: all 0.3s ease;
	width: 40px;
    height: 40px;
    line-height: 38px;
	    display: flex;
    align-items: center;
    justify-content: center;
	margin-right: 7px;
}
.tbs__paginate a:hover, .tbs__paginate span {
    color: #ffffff !important;
    background-color: #2aacf1;
    box-shadow: none;
    border-color: #2aacf1;
}
.tbs__form {
	   display: grid;

    grid-template-columns: repeat(1, 1fr);
    padding: 0 24px;
	width: 100%;
	
}
.tbs__form_submit {
	margin-right:0;
	color: #fff;
}
@media (min-width: 768px) {
	.tbs__form {
    gap: 30px;
    grid-template-columns: repeat(3, 1fr);
}
}

div.title.bg {
    background-image: linear-gradient(to right, #2aacf1, #2aacf1);
}
.header-button .icon {
	border-color: rgba(255,255,255,0.5);
}
</style></head>

